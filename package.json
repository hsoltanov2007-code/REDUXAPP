{
  "name": "hardy-monorepo",
  "private": true,
  "workspaces": [
    "apps/server",
    "apps/desktop"
  ],
  "scripts": {
    "dev:server": "npm --workspace apps/server run dev",
    "dev:desktop": "npm --workspace apps/desktop run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:desktop\"",
    "build": "npm --workspace apps/server run build && npm --workspace apps/desktop run build",
    "dist:win": "npm --workspace apps/desktop run dist:win"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
